<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>10-Phase Boss Gauntlet</title>
    <style>
        body { background: #111; color: #fff; font-family: sans-serif; text-align: center; padding: 20px; }
        .container { max-width: 600px; margin: 0 auto; background: #222; padding: 20px; border-radius: 10px; border: 2px solid #444; }
        .health-bar { background: #444; width: 100%; height: 25px; border-radius: 5px; margin: 10px 0; overflow: hidden; position: relative; }
        .health-fill { height: 100%; width: 100%; transition: width 0.3s; }
        #boss-health { background: #ff3333; }
        #player-health { background: #33ff33; }
        .bar-text { position: absolute; width: 100%; text-align: center; font-weight: bold; line-height: 25px; color: white; }
        button { background: #444; color: white; border: none; padding: 12px 24px; margin: 5px; font-size: 16px; border-radius: 5px; cursor: pointer; }
        button:hover { background: #666; }
        #log { background: #000; padding: 10px; height: 120px; overflow-y: auto; text-align: left; font-family: monospace; font-size: 14px; border: 1px solid #333; margin-top: 15px; }
        .phase-banner { font-size: 24px; color: #ffcc00; font-weight: bold; margin: 10px 0; }
    </style>
</head>
<body>

<div class="container">
    <h1>The Ultimate Showdown</h1>
    
    <!-- Boss UI -->
    <div id="boss-name" class="phase-banner">Phase 1: Shadow Apprentice</div>
    <div class="health-bar">
        <div id="boss-health" class="health-fill"></div>
        <div id="boss-text" class="bar-text">Boss HP: 1000 / 1000</div>
    </div>

    <!-- Player UI -->
    <h3>Your Status</h3>
    <div class="health-bar">
        <div id="player-health" class="health-fill"></div>
        <div id="player-text" class="bar-text">Player HP: 100 / 100</div>
    </div>
    <div id="shield-status" style="color: #33ccff; font-weight: bold;">Shield: INACTIVE</div>

    <!-- The 3 Abilities -->
    <div style="margin-top: 20px;">
        <button onclick="useAbility('attack')">⚔️ Strike</button>
        <button onclick="useAbility('heal')">❤️ Rejuvenate</button>
        <button onclick="useAbility('shield')">🛡️ Aegis Barrier</button>
    </div>

    <div id="log">Battle logged... Defeat the boss through all 10 transformations!</div>
</div>

<script>
    // Game State
    let maxBossHp = 1000;
    let bossHp = 1000;
    let playerMaxHp = 100;
    let playerHp = 100;
    let isShielded = false;
    let currentPhase = 1;

    // Boss Phase Configuration (1 to 10)
    const phases = {
        1: { name: "Shadow Apprentice", damage: 6 },
        2: { name: "Flame Adept", damage: 9 },
        3: { name: "Frost Knight", damage: 12 },
        4: { name: "Void Stalker", damage: 15 },
        5: { name: "Storm Summoner", damage: 18 },
        6: { name: "Corrupted General", damage: 22 },
        7: { name: "Abyss Archmage", damage: 26 },
        8: { name: "Dragon Soul Avatar", damage: 31 },
        9: { name: "Chaos Harbinger", damage: 37 },
        10: { name: "God-King of Ruin", damage: 45 }
    };

    function logMessage(msg) {
        const log = document.getElementById('log');
        log.innerHTML += `<div>${msg}</div>`;
        log.scrollTop = log.scrollHeight;
    }

    function updateUI() {
        // Update Boss
        const bossPct = Math.max(0, (bossHp / maxBossHp) * 100);
        document.getElementById('boss-health').style.width = bossPct + '%';
        document.getElementById('boss-text').innerText = `Boss HP: ${Math.ceil(bossHp)} / ${maxBossHp}`;
        document.getElementById('boss-name').innerText = `Phase ${currentPhase}: ${phases[currentPhase].name}`;

        // Update Player
        const playerPct = Math.max(0, (playerHp / playerMaxHp) * 100);
        document.getElementById('player-health').style.width = playerPct + '%';
        document.getElementById('player-text').innerText = `Player HP: ${playerHp} / ${playerMaxHp}`;
        document.getElementById('shield-status').innerText = isShielded ? "Shield: ACTIVE (Blocks 50% Damage)" : "Shield: INACTIVE";
    }

    function useAbility(type) {
        if (playerHp <= 0 || bossHp <= 0) return;

        if (type === 'attack') {
            let dmg = Math.floor(Math.random() * 15) + 15; // 15-30 dmg
            bossHp -= dmg;
            logMessage(`⚔️ You strike the boss for ${dmg} damage.`);
            checkPhaseProgression();
        } 
        else if (type === 'heal') {
            let heal = 35;
            playerHp = Math.min(playerMaxHp, playerHp + heal);
            logMessage(`❤️ You cast Rejuvenate and heal for ${heal} HP.`);
        } 
        else if (type === 'shield') {
            isShielded = true;
            logMessage(`🛡️ You raise your Aegis Barrier for the next turn.`);
        }

        // If boss survives, it counter-attacks
        if (bossHp > 0) {
            bossTurn();
        } else {
            logMessage("🎉 VICTORY! You have vanquished all 10 phases of the boss!");
        }
        updateUI();
    }

    function checkPhaseProgression() {
        // Calculate what phase the boss should be based on remaining HP (every 100 HP dropped = 1 phase lower)
        let calculatedPhase = 11 - Math.ceil(bossHp / 100);
        if (calculatedPhase > currentPhase && calculatedPhase <= 10) {
            currentPhase = calculatedPhase;
            logMessage(`⚠️ WARNING: The boss morphs into Phase ${currentPhase}: ${phases[currentPhase].name}!`);
        }
    }

    function bossTurn() {
        let baseDmg = phases[currentPhase].damage;
        // Add minor variance to boss attacks (+/- 2)
        let actualDmg = Math.floor(Math.random() * 5) + (baseDmg - 2);
        
        if (isShielded) {
            actualDmg = Math.floor(actualDmg * 0.5); // Shield blocks half damage
            isShielded = false; // Shield breaks after one hit
            logMessage(`🛡️ Your barrier absorbs half the impact!`);
        }

        playerHp -= actualDmg;
        logMessage(`💥 The ${phases[currentPhase].name} hits you for ${actualDmg} damage.`);

        if (playerHp <= 0) {
            playerHp = 0;
            logMessage("💀 GAME OVER! You were crushed by the boss.");
        }
    }

    // Initial draw
    updateUI();
</script>
</body>
</html>
